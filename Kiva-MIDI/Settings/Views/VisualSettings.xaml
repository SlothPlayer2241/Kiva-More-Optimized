<UserControl x:Class="Kiva.Settings.Views.VisualSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="clr-namespace:Kiva.UI">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../ButtonTemplates.xaml"/>
                <ResourceDictionary Source="../../Scrollbar.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>

        <!-- Background -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FF9B5C"/>
                <GradientStop Color="#FF6B9D" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDE -->
        <Border Padding="10">
            <StackPanel>

                <!-- Key Range -->
                <Label Foreground="White" FontSize="14">Keyboard Key Range</Label>

                <ui:BetterRadio x:Name="key88Range" Text="88 Keys" RadioChecked="RangeChanged"/>
                <ui:BetterRadio x:Name="key128Range" Text="128 Keys" RadioChecked="RangeChanged"/>
                <ui:BetterRadio x:Name="key256Range" Text="256 Keys" RadioChecked="RangeChanged"/>

                <ui:BetterRadio x:Name="midiRange" Text="MIDI's Key Range" ParentDepth="2" RadioChecked="RangeChanged"/>
                <ui:BetterRadio x:Name="dynamicRange" Text="Dynamic 88-128 Range" ParentDepth="2" RadioChecked="RangeChanged"/>

                <!-- Custom range -->
                <DockPanel Margin="0,5,0,0">

                    <ui:BetterRadio x:Name="customRange"
                                    Text="Custom"
                                    ParentDepth="2"
                                    RadioChecked="RangeChanged"/>

                    <ui:NumberSelect x:Name="firstKey"
                                     Minimum="0"
                                     Maximum="{Binding ElementName=lastKey, Path=Value}"
                                     ValueChanged="FirstKey_ValueChanged"
                                     Width="70"
                                     IsEnabled="{Binding ElementName=customRange, Path=IsChecked}"/>

                    <Label>To</Label>

                    <ui:NumberSelect x:Name="lastKey"
                                     Minimum="{Binding ElementName=firstKey, Path=Value}"
                                     Maximum="256"
                                     ValueChanged="LastKey_ValueChanged"
                                     Width="70"
                                     IsEnabled="{Binding ElementName=customRange, Path=IsChecked}"/>

                </DockPanel>

                <!-- Keyboard Style -->
                <Label Foreground="White" FontSize="14" Margin="0,10,0,0">Keyboard Style</Label>

                <ui:BetterRadio x:Name="bigKeyboard" Text="Big Keyboard" RadioChecked="KBStyleChanged"/>
                <ui:BetterRadio x:Name="smallKeyboard" Text="Small Keyboard" RadioChecked="KBStyleChanged"/>
                <ui:BetterRadio x:Name="noKeyboard" Text="No Keyboard" RadioChecked="KBStyleChanged"/>

                <!-- FPS -->
                <DockPanel Margin="0,10,0,0">

                    <Label Foreground="White">Lock FPS</Label>

                    <ui:NumberSelect x:Name="fpsLock"
                                     Minimum="0"
                                     Maximum="10000"
                                     ValueChanged="FpsLock_ValueChanged"
                                     Width="80"/>

                    <ui:BetterCheckbox x:Name="syncFps"
                                       Text="Sync"
                                       Margin="10,0,0,0"
                                       CheckToggled="syncFps_CheckToggled"/>

                    <ui:InfoIcon Title="FPS"
                                 Text="Sync forces WPF render framerate. Setting 0 unlocks FPS."
                                 Margin="5,0,0,0"/>

                </DockPanel>

            </StackPanel>
        </Border>

        <!-- RIGHT SIDE -->
        <Border Grid.Column="1" Padding="10">

            <DockPanel>

                <!-- Header -->
                <DockPanel DockPanel.Dock="Top">

                    <Label Foreground="White" FontSize="14">
                        Note Color Palette
                    </Label>

                    <ui:InfoIcon Title="Palettes"
                                 Text="PNG palettes (16 or 32px wide). Columns = MIDI channels."
                                 />

                    <Button x:Name="reloadPalettes"
                            Content="Reload"
                            PreviewMouseDown="ReloadPalettes_PreviewMouseDown"
                            Style="{DynamicResource TransparentButtonStyle}"
                            Width="80"
                            HorizontalAlignment="Right"/>

                </DockPanel>

                <!-- Controls -->
                <DockPanel DockPanel.Dock="Bottom" Margin="0,5,0,0">

                    <ui:BetterCheckbox x:Name="randomisePaletteOrder"
                                       Text="Randomise Color Order"
                                       CheckToggled="RandomisePaletteOrder_CheckToggled"/>

                    <ui:InfoIcon Title="Randomise color order"
                                 Text="Shuffle palette colors"
                                 Margin="5,0,0,2"/>

                </DockPanel>

                <Button x:Name="openPaletteFolder"
                        Content="Open Palette Folder"
                        PreviewMouseDown="OpenPaletteFolder_PreviewMouseDown"
                        Style="{DynamicResource TransparentButtonStyle}"
                        Width="140"
                        Height="25"
                        HorizontalAlignment="Center"
                        DockPanel.Dock="Bottom"/>

                <!-- Palette list -->
                <Border BorderBrush="Black" BorderThickness="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="palettesPanel"/>
                    </ScrollViewer>
                </Border>

            </DockPanel>

        </Border>

    </Grid>
</UserControl>
