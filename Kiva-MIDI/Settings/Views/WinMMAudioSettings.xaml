<UserControl x:Class="Kiva.Settings.Views.WinMMAudioSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Kiva.Settings.Views">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../ButtonTemplates.xaml"/>
                <ResourceDictionary Source="../../Scrollbar.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>

        <!-- Background -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FF9B5C"/>
                <GradientStop Color="#FF6B9D" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <DockPanel>

            <!-- Header -->
            <Label DockPanel.Dock="Top"
                   Foreground="White"
                   Content="MIDI Output Device"/>

            <!-- Device list -->
            <Border BorderThickness="0">

                <ScrollViewer>

                    <StackPanel x:Name="devicesList"
                                Background="Transparent"/>

                </ScrollViewer>

            </Border>

        </DockPanel>

    </Grid>
</UserControl>
