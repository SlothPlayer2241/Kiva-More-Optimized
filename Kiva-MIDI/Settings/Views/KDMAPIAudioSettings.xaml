<UserControl x:Class="Kiva.Settings.Views.KDMAPIAudioSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">

    <Grid>

        <!-- Lightweight gradient (same style as rest of app) -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FF9B5C"/>
                <GradientStop Color="#FF6B9D" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Placeholder (no heavy controls yet) -->
        <TextBlock Text="KDMAPI Settings (Coming Soon)"
                   Foreground="White"
                   FontSize="16"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Opacity="0.7"/>

    </Grid>
</UserControl>
