<UserControl x:Class="Kiva.Settings.Views.AudioSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Kiva.Settings.Views">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../ButtonTemplates.xaml"/>
                <ResourceDictionary Source="../../Scrollbar.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <DockPanel>

        <!-- Top: Engine Selector -->
        <Border DockPanel.Dock="Top">

            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#FF6B9D"/>
                    <GradientStop Color="#FF9B5C" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <DockPanel HorizontalAlignment="Center">

                <Label Foreground="White" FontSize="16">
                    Rendering Engine:
                </Label>

                <Button x:Name="kdmapiEngine"
                        Content="KDMAPI"
                        Width="120"
                        FontSize="16"
                        Style="{DynamicResource TransparentButtonStyle}"/>

                <Button x:Name="winmmEngine"
                        Content="WinMM"
                        Width="120"
                        FontSize="16"
                        Style="{DynamicResource TransparentButtonStyle}"/>

                <Button x:Name="prerenderEngine"
                        Content="Pre-Render"
                        Width="120"
                        FontSize="16"
                        Style="{DynamicResource TransparentButtonStyle}"/>

            </DockPanel>
        </Border>

        <!-- Bottom: Engine Settings -->
        <Grid>

            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FF9B5C"/>
                    <GradientStop Color="#FF6B9D" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <local:KDMAPIAudioSettings x:Name="kdmapiSettings"/>
            <local:WinMMAudioSettings x:Name="winmmSettings"/>
            <local:PreRenderAudioSettings x:Name="prerenderSettings"/>

        </Grid>

    </DockPanel>
</UserControl>
