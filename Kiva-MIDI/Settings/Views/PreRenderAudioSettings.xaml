<UserControl x:Class="Kiva.Settings.Views.PreRenderAudioSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Kiva.Settings.Views"
             xmlns:ui="clr-namespace:Kiva.UI"
             Unloaded="UserControl_Unloaded">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../ButtonTemplates.xaml"/>
                <ResourceDictionary Source="../../Scrollbar.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <DockPanel LastChildFill="True">

        <!-- Top settings -->
        <Grid DockPanel.Dock="Top">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#FF6B9D"/>
                    <GradientStop Color="#FF9B5C" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- Left -->
            <StackPanel Margin="5">

                <DockPanel>
                    <Label Foreground="White" Content="Buffer length (seconds):"/>
                    <ui:NumberSelect x:Name="bufferLength"
                                     Minimum="10" Maximum="3600" Value="60"
                                     Width="100"
                                     ValueChanged="bufferLength_ValueChanged"/>
                    <Label x:Name="bufferSizeLabel" Content="(0mb)"/>
                </DockPanel>

                <DockPanel Margin="0,5,0,0">
                    <Label Foreground="White" Content="Simulated Realtime Lag (ms)"/>
                    <ui:NumberSelect x:Name="simulatedLag"
                                     Minimum="0" Maximum="1000" Value="0"
                                     Width="100"
                                     ValueChanged="simulatedLag_ValueChanged"/>
                    <ui:InfoIcon Margin="5,0,0,0"
                                 Title="Simulated Realtime Lag"
                                 Text="Adds artificial delay to simulate realtime playback."/>
                </DockPanel>

            </StackPanel>

            <!-- Right -->
            <StackPanel Grid.Column="1" Margin="5">

                <DockPanel>
                    <Label Foreground="White" Content="Voices:"/>
                    <ui:NumberSelect x:Name="voices"
                                     Minimum="32" Maximum="5000" Value="500"
                                     Width="100"
                                     ValueChanged="voices_ValueChanged"/>
                </DockPanel>

                <ui:BetterCheckbox x:Name="disableFx"
                                   Margin="0,5,0,0"
                                   Text="Disable Soundfont Effects"
                                   CheckToggled="disableFx_CheckToggled"/>

            </StackPanel>
        </Grid>

        <!-- Soundfont list -->
        <DockPanel Margin="10">

            <!-- Controls -->
            <StackPanel DockPanel.Dock="Right">

                <Button x:Name="addButton" Width="20" Height="20"
                        Style="{DynamicResource TransparentButtonStyle}"
                        Click="addButton_Click">+</Button>

                <Button x:Name="removeButton" Width="20" Height="20"
                        Style="{DynamicResource TransparentButtonStyle}"
                        Click="removeButton_Click">-</Button>

                <Button x:Name="upButton" Width="20" Height="20"
                        Margin="0,10,0,0"
                        Style="{DynamicResource TransparentButtonStyle}"
                        Click="upButton_Click">🡅</Button>

                <Button x:Name="downButton" Width="20" Height="20"
                        Style="{DynamicResource TransparentButtonStyle}"
                        Click="downButton_Click">🡇</Button>

            </StackPanel>

            <!-- List -->
            <Border x:Name="sfPanel"
                    BorderBrush="Black"
                    BorderThickness="1"
                    AllowDrop="True"
                    PreviewDrop="sfPanel_PreviewDrop"
                    PreviewDragEnter="sfPanel_PreviewDragEnter"
                    PreviewDragLeave="sfPanel_PreviewDragLeave">

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="sfList"/>
                </ScrollViewer>

            </Border>

        </DockPanel>

    </DockPanel>
</UserControl>
